{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "SmtpSettings": {
    "Host": "${SMTP_HOST}",
    "Port": 587,
    "Username": "${SMTP_USER}",
    "Password": "${SMTP_PASSWORD}",
    "FromAddress": "${SMTP_FROM_ADDRESS}",
    "FromName": "Insurance Claim System",
    "EnableSsl": true
  },
  "StripeSettings": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}"
  },
  "FileStorageSettings": {
    "UploadPath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".pdf", ".doc", ".docx", ".webp"]
  },
  "AllowedOrigins": [
    "https://insuranceclaimsystem.com",
    "https://admin.insuranceclaimsystem.com"
  ],
  "EncryptionSettings": {
    "Key": "${AES_ENCRYPTION_KEY}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
